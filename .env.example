# ============================================
# SHOPIFY SEO AUDITOR - ENVIRONMENT VARIABLES
# ============================================

# ============ APPLICATION ============
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ============ DATABASE ============
DB_USER=admin
DB_PASSWORD=changeme123!
DATABASE_URL=postgresql://admin:changeme123!@localhost:5432/shopify_auditor

# ============ REDIS ============
REDIS_PASSWORD=redispass123!
REDIS_URL=redis://:redispass123!@localhost:6379

# ============ JWT AUTHENTICATION ============
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-this
REFRESH_TOKEN_EXPIRES_IN=30d

# ============ STRIPE PAYMENTS ============
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============ SHOPIFY ============
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_APP_URL=https://your-app.myshopify.com

# ============ EXTERNAL APIS ============
GOOGLE_PAGESPEED_API_KEY=your_google_pagespeed_api_key
LIGHTHOUSE_API_KEY=your_lighthouse_api_key

# ============ EMAIL (RESEND) ============
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=audits@yourdomain.com
EMAIL_SUPPORT=support@yourdomain.com

# ============ FILE STORAGE ============
# Option 1: Backblaze B2 (Recommended)
STORAGE_PROVIDER=b2
B2_ACCOUNT_ID=your_b2_account_id
B2_APPLICATION_KEY=your_b2_application_key
B2_BUCKET_NAME=shopify-audits
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com

# Option 2: AWS S3
# STORAGE_PROVIDER=s3
# S3_ACCESS_KEY_ID=your_s3_access_key
# S3_SECRET_ACCESS_KEY=your_s3_secret_key
# S3_REGION=eu-west-1
# S3_BUCKET=shopify-audits
# S3_ENDPOINT=https://s3.eu-west-1.amazonaws.com

# ============ MONITORING ============
GRAFANA_PASSWORD=grafana_admin_password
PROMETHEUS_PASSWORD=prometheus_password

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ============ FEATURE FLAGS ============
FEATURE_PDF_EXPORT=true
FEATURE_EMAIL_REPORTS=true
FEATURE_API_ACCESS=false
FEATURE_REALTIME_MONITORING=false

# ============ PRICING (in cents) ============
PRICE_SINGLE_AUDIT=999        # 9.99€
PRICE_PACK_5=3999            # 39.99€
PRICE_PACK_20=14999          # 149.99€
PRICE_UNLIMITED_MONTHLY=29999 # 299.99€
PRICE_AGENCY=49999           # 499.99€

# ============ AUDIT LIMITS ============
FREE_AUDITS_PER_MONTH=1
SINGLE_AUDITS_PER_MONTH=1
PACK_5_AUDITS_PER_MONTH=5
PACK_20_AUDITS_PER_MONTH=20
UNLIMITED_AUDITS_PER_MONTH=9999
AGENCY_AUDITS_PER_MONTH=9999

# ============ SECURITY ============
ADMIN_API_KEY=your_admin_api_key_for_internal_use
ENCRYPTION_KEY=32_byte_encryption_key_for_sensitive_data

# ============ LOGGING ============
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
SENTRY_DSN=your_sentry_dsn_for_error_tracking

# ============ DEVELOPMENT ============
DEBUG=backend:*,frontend:*
NODE_TLS_REJECT_UNAUTHORIZED=0  # For self-signed certs in dev